# InsForge (Auth + Postgres). Get these from InsForge dashboard → Project Settings → API.
NEXT_PUBLIC_INSFORGE_URL=https://your-project.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=
# Project admin API key — server-only, bypasses RLS. Never expose to the browser.
INSFORGE_API_KEY=

# Public origin, used to build OAuth redirect URLs (no trailing slash).
# Optional locally (we fall back to the request origin); set it in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

OPENAI_API_KEY=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
